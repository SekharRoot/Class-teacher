rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data : {};
    }
    
    function isActive() {
      return isAuthenticated() && getUserData().status == 'active';
    }
    
    function isOwner() {
      return (isAuthenticated() && request.auth.token.email == 'sekhar.root@gmail.com') || (isActive() && getUserData().role == 'owner');
    }

    function isAdminOrOwner() {
      return (isAuthenticated() && request.auth.token.email == 'sekhar.root@gmail.com') || (isActive() && (getUserData().role == 'admin' || getUserData().role == 'owner'));
    }

    function isCoordinator() {
      return isActive() && getUserData().role == 'academic_coordinator';
    }

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection Group Queries
    match /{path=**}/students/{studentId} {
      allow read, write: if isActive() || isAdminOrOwner();
    }
    
    match /{path=**}/leaves/{leaveId} {
      allow read: if isActive() || isAdminOrOwner();
      allow write: if isAdminOrOwner() || (isActive() && getUserData().get('hasLeaveFeatureAccess', false) == true);
    }
    
    match /{path=**}/attendance/{date} {
      allow read, write: if isActive() || isAdminOrOwner();
    }

    // Classroom manager collections
    // Only active users can read and write standard collections for now.
    // In a production app, you might restrict this further (e.g. teachers only writing to their own class)
    match /schools/{schoolId} {
      // Anyone can read schools (necessary for the registration dropdown)
      allow read: if true;
      // Only owners/admins can write (add/remove) schools
      allow write: if isAdminOrOwner();

      match /attendance_summaries/{date} {
        allow read, write: if isActive() || isAdminOrOwner();
      }

      match /classes/{classId} {
        allow read, write: if isActive() || isAdminOrOwner();

        match /students/{studentId} {
          allow read, write: if isActive() || isAdminOrOwner();
        }

        match /leaves/{leaveId} {
          allow read: if isActive() || isAdminOrOwner();
          allow write: if isAdminOrOwner() || (isActive() && getUserData().get('hasLeaveFeatureAccess', false) == true);
        }

        match /attendance/{date} {
          allow read, write: if isActive() || isAdminOrOwner();
        }
      }
    }

    match /students/{studentId} {
      allow read, write: if isActive() || isAdminOrOwner();
    }
    
    match /attendance/{date} {
      allow read, write: if isActive() || isAdminOrOwner();
    }

    match /attendance_summaries/{date} {
      allow read, write: if isActive() || isAdminOrOwner();
    }

    match /class_daily_attendance/{docId} {
      allow read, write: if isActive() || isAdminOrOwner();
    }
    
    match /classes/{classId} {
      allow read, write: if isActive() || isAdminOrOwner();
    }

    match /leaves/{leaveId} {
      // Allow read for all active users so they can see their relevant data
      // Write remains restricted to admin/owner or those with explicit access
      allow read: if isActive() || isAdminOrOwner();
      allow write: if isAdminOrOwner() || (isActive() && getUserData().get('hasLeaveFeatureAccess', false) == true);
    }

    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed for UI lists, etc.)
      allow read: if isAuthenticated();
      
      // Creating a user profile during signup is allowed if it's their own ID, or if admin/owner creates a pre-configured account
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdminOrOwner());
                    
      // Updating a user profile
      allow update: if isAuthenticated() && (
        // Admins/Owners can update any profile
        isAdminOrOwner() ||
        // Academic Coordinators can update substitute teacher classes (only for class_teacher accounts to prevent privilege escalation)
        (isCoordinator() && resource.data.role == 'class_teacher') ||
        // Users can update their own profile, BUT they cannot change their role or status
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.status == resource.data.status)
      );
      
      // Only Admins/Owners can delete users, OR a user can delete their own pre-configured profile
      allow delete: if isAdminOrOwner() || 
                    (isAuthenticated() && userId.matches('^pre_.*') && resource.data.email == request.auth.token.email);
    }
  }
}
