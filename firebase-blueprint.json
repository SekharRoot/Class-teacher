{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student in the classroom with optional profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "rollNumber": { "type": "string" },
        "classId": { "type": "string" },
        "gender": {
          "type": "string",
          "enum": ["Male", "Female", "Transgender"]
        },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "image": { "type": "string" },
        "boarderType": {
          "type": "string",
          "enum": ["Day boarder", "Day Scholar", "Full Boarder"]
        }
      },
      "required": ["id", "firstName", "lastName", "rollNumber"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "A daily attendance sheet where keys are student IDs and values are attendance statuses (present, absent, leave)",
      "type": "object",
      "properties": {
        "statusMap": {
          "type": "object",
          "description": "Dynamic mapping of student IDs to their attendance status"
        }
      }
    },
    "ClassItem": {
      "title": "ClassItem",
      "description": "A classroom containing standard, section, and board info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "board": { "type": "string" },
        "classStandard": { "type": "string" },
        "section": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "board", "classStandard", "section"]
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "description": "A student's leave request record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "reason": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "appliedBy": { "type": "string" },
        "appliedById": { "type": "string" },
        "appliedAt": { "type": "string" },
        "resolvedBy": { "type": "string" },
        "resolvedById": { "type": "string" },
        "resolvedAt": { "type": "string" }
      },
      "required": [
        "id",
        "studentId",
        "classId",
        "startDate",
        "endDate",
        "reason",
        "status",
        "appliedBy",
        "appliedById",
        "appliedAt"
      ]
    }
  },
  "firestore": {
    "students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students in the classroom"
    },
    "attendance/{date}": {
      "schema": "AttendanceRecord",
      "description": "Attendance records keyed by date string (YYYY-MM-DD)"
    },
    "classes/{classId}": {
      "schema": "ClassItem",
      "description": "Collection of available classrooms"
    },
    "leaves/{leaveId}": {
      "schema": "LeaveRequest",
      "description": "Collection of student leave requests"
    }
  }
}
